{
	"SessionStart": [
		{
			"hooks": [
				{
					"type": "command",
					"command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/llm-wiki-pm/hooks/session-start.sh\"",
					"statusMessage": "Checking wiki health..."
				}
			]
		}
	],
	"PostToolUse": [
		{
			"matcher": "Write|Edit",
			"hooks": [
				{
					"type": "command",
					"command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/llm-wiki-pm/hooks/post-write.sh\"",
					"async": true
				}
			]
		}
	],
	"SessionEnd": [
		{
			"hooks": [
				{
					"type": "command",
					"command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/llm-wiki-pm/hooks/session-stop.sh\""
				}
			]
		}
	]
}
