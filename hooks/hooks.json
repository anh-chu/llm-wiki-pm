{
	"description": "Wiki health check, backlink validation, and log rotation hooks for llm-wiki-pm",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
						"statusMessage": "Checking wiki health..."
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-write.sh\"",
						"async": true
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-stop.sh\""
					}
				]
			}
		]
	}
}
